<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<!-- ═══════════════════════════════════════════════════════════
     Login — Material Design 3 Warm/Olive theme
     Adaptado del mockup HTML provisto por el usuario
     Funciona en desktop (centrado) y como base para mobile
═══════════════════════════════════════════════════════════ -->
<StackPane xmlns="http://javafx.com/javafx/21"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.crm.personal.presentation.controller.LoginController"
           style="-fx-background-color: #FDFBF7;"
           prefWidth="520" prefHeight="420">

    <!-- Card centrada (max 380px) -->
    <VBox alignment="CENTER" spacing="0" maxWidth="380" minWidth="320"
          style="-fx-background-color: #ffffff;
                 -fx-background-radius: 10;
                 -fx-border-color: #c7c7bc;
                 -fx-border-radius: 10;
                 -fx-border-width: 1;
                 -fx-effect: dropshadow(gaussian, #00000010, 14, 0, 0, 3);
                 -fx-padding: 40 40 36 40;">

        <!-- ── Header ──────────────────────────────────────────── -->
        <VBox alignment="CENTER" spacing="10">
            <padding><Insets bottom="24"/></padding>

            <!-- Ícono (círculo de acento) -->
            <StackPane prefWidth="72" prefHeight="72"
                       style="-fx-background-color: #d4eca2;
                              -fx-background-radius: 16;">
                <Label text="🔐" style="-fx-font-size:30px;"/>
            </StackPane>

            <Label text="CRM Personal"
                   style="-fx-font-size:22px; -fx-font-weight:600; -fx-text-fill:#1e1b16;"/>
            <Label text="Ingresa tu contraseña maestra"
                   style="-fx-font-size:14px; -fx-text-fill:#46483f;"/>
        </VBox>

        <!-- ── Form ────────────────────────────────────────────── -->
        <VBox spacing="14" maxWidth="340">

            <!-- Label del campo -->
            <Label text="Contraseña maestra"
                   style="-fx-font-size:11px; -fx-font-weight:bold;
                          -fx-text-fill:#46483f; -fx-padding:0 0 2 0;"/>

            <!-- PasswordField -->
            <PasswordField fx:id="passwordField"
                           promptText="••••••••"
                           style="-fx-background-color:#ffffff; -fx-text-fill:#1e1b16;
                                  -fx-prompt-text-fill:#77786e;
                                  -fx-border-color:#c7c7bc; -fx-border-radius:6;
                                  -fx-background-radius:6; -fx-padding:11 14;
                                  -fx-font-size:14px;"/>

            <!-- Error -->
            <Label fx:id="errorLabel"
                   style="-fx-text-fill:#ba1a1a; -fx-font-size:12px; -fx-padding:0;"
                   wrapText="true"/>

            <!-- Botón Acceder -->
            <Button fx:id="loginButton" text="Acceder"
                    onAction="#handleLogin"
                    maxWidth="Infinity"
                    style="-fx-background-color:#5a6147; -fx-text-fill:#ffffff;
                           -fx-font-weight:700; -fx-font-size:14px;
                           -fx-padding:11 0; -fx-background-radius:6; -fx-cursor:hand;
                           -fx-border-color:transparent;"/>
        </VBox>

    </VBox>
</StackPane>
