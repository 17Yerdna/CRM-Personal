<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.crm.personal.presentation.controller.EtiquetaManagerController"
      spacing="16"
      style="-fx-background-color:#1e1e2e; -fx-padding:20;"
      prefWidth="560" prefHeight="480">

    <!-- Panel izquierdo: árbol -->
    <VBox spacing="8" prefWidth="220"
          style="-fx-background-color:#2a2a3e; -fx-background-radius:8; -fx-padding:14;">
        <Label text="Etiquetas existentes"
               style="-fx-font-weight:bold; -fx-text-fill:#a78bfa;"/>
        <TreeView fx:id="etiquetasTree" VBox.vgrow="ALWAYS"
                  style="-fx-background-color:#2a2a3e; -fx-border-color:transparent;"/>
        <HBox spacing="6">
            <Button fx:id="btnNueva" text="+ Nueva"
                    onAction="#handleNueva" HBox.hgrow="ALWAYS"
                    style="-fx-background-color:#6c63ff; -fx-text-fill:white;
                           -fx-background-radius:4; -fx-cursor:hand; -fx-padding:7;"/>
            <Button fx:id="btnEliminar" text="&#128465;&#65039;"
                    onAction="#handleEliminar"
                    style="-fx-background-color:#3e1e1e; -fx-text-fill:#ff8080;
                           -fx-background-radius:4; -fx-cursor:hand; -fx-padding:7 10;"/>
        </HBox>
    </VBox>

    <!-- Panel derecho: formulario -->
    <VBox spacing="14" HBox.hgrow="ALWAYS"
          style="-fx-background-color:#2a2a3e; -fx-background-radius:8; -fx-padding:20;">
        <Label text="Editar etiqueta"
               style="-fx-font-weight:bold; -fx-text-fill:#a78bfa; -fx-font-size:14px;"/>
        <Separator/>

        <Label text="Nombre:" style="-fx-text-fill:#c0c0d0;"/>
        <TextField fx:id="nombreField" promptText="Nombre de la etiqueta"
                   style="-fx-background-color:#3d3d5c; -fx-text-fill:white;
                          -fx-border-color:#4a4a6a; -fx-border-radius:4;
                          -fx-background-radius:4; -fx-padding:8 10;"/>

        <Label text="Color:" style="-fx-text-fill:#c0c0d0;"/>
        <ColorPicker fx:id="colorPicker" maxWidth="Infinity"
                     style="-fx-background-color:#3d3d5c; -fx-background-radius:4;"/>

        <Label text="Etiqueta padre (opcional):" style="-fx-text-fill:#c0c0d0;"/>
        <ComboBox fx:id="padreCombo" maxWidth="Infinity"
                  promptText="Sin padre (raíz)"
                  style="-fx-background-color:#3d3d5c; -fx-background-radius:4;"/>

        <Region VBox.vgrow="ALWAYS"/>

        <HBox spacing="8" alignment="CENTER_RIGHT">
            <Button text="&#10005; Cerrar"
                    onAction="#handleCerrar"
                    style="-fx-background-color:#3d3d5c; -fx-text-fill:#c0c0e0;
                           -fx-background-radius:4; -fx-cursor:hand; -fx-padding:8 16;"/>
            <Button fx:id="btnGuardar" text="&#128190; Guardar"
                    onAction="#handleGuardar"
                    style="-fx-background-color:#6c63ff; -fx-text-fill:white;
                           -fx-font-weight:bold; -fx-background-radius:4;
                           -fx-cursor:hand; -fx-padding:8 20;"/>
        </HBox>
    </VBox>
</HBox>
