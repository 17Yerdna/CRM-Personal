<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.crm.personal.presentation.controller.MainController"
            style="-fx-background-color:#1e1e2e;"
            prefWidth="1200" prefHeight="760">

    <!-- ── TOOLBAR SUPERIOR ─────────────────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14"
              style="-fx-background-color:#12121e; -fx-padding:10 18;
                     -fx-border-color:#2d2d4e; -fx-border-width:0 0 1 0;">
            <Label text="&#128196; CRM Personal"
                   style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#a78bfa;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblContadorContactos"
                   style="-fx-text-fill:#6060a0; -fx-font-size:12px;"/>
        </HBox>
    </top>

    <!-- ── CONTENIDO PRINCIPAL (3 paneles) ──────────────────────────────── -->
    <center>
        <SplitPane dividerPositions="0.19, 0.43"
                   style="-fx-background-color:#1e1e2e;">

            <!-- PANEL IZQUIERDO: Etiquetas + operador búsqueda ──────────── -->
            <VBox spacing="8" minWidth="170" maxWidth="260"
                  style="-fx-background-color:#14141f; -fx-padding:14;">

                <Label text="Etiquetas"
                       style="-fx-font-weight:bold; -fx-text-fill:#a78bfa; -fx-font-size:13px;"/>

                <TreeView fx:id="etiquetasTreeView" VBox.vgrow="ALWAYS"
                          style="-fx-background-color:#14141f; -fx-border-color:transparent;"/>

                <Separator style="-fx-background-color:#2d2d4e;"/>

                <Label text="Operador de búsqueda:"
                       style="-fx-text-fill:#9090b0; -fx-font-size:11px;"/>

                <HBox spacing="14">
                    <RadioButton fx:id="radioAnd" text="AND" selected="true"
                                 style="-fx-text-fill:#c0c0d0;"
                                 onAction="#handleBuscar">
                        <toggleGroup><ToggleGroup fx:id="opGroup"/></toggleGroup>
                    </RadioButton>
                    <RadioButton fx:id="radioOr" text="OR"
                                 style="-fx-text-fill:#c0c0d0;"
                                 toggleGroup="$opGroup"
                                 onAction="#handleBuscar"/>
                </HBox>

                <Button fx:id="btnNuevaEtiqueta" text="+ Nueva Etiqueta"
                        onAction="#handleNuevaEtiqueta" maxWidth="Infinity"
                        style="-fx-background-color:#2d2d4e; -fx-text-fill:#a78bfa;
                               -fx-background-radius:4; -fx-cursor:hand; -fx-padding:6;"/>
            </VBox>

            <!-- PANEL CENTRAL: Lista de contactos ──────────────────────── -->
            <VBox spacing="8" minWidth="240" maxWidth="380"
                  style="-fx-background-color:#1a1a2b; -fx-padding:14;">

                <TextField fx:id="searchField"
                           promptText="&#128269; Buscar contacto..."
                           style="-fx-background-color:#2d2d3f; -fx-text-fill:white;
                                  -fx-border-color:#4a4a6a; -fx-border-radius:6;
                                  -fx-background-radius:6; -fx-padding:8;"/>

                <ListView fx:id="contactosListView" VBox.vgrow="ALWAYS"
                          style="-fx-background-color:#1a1a2b; -fx-border-color:transparent;"/>

                <HBox spacing="6">
                    <Button fx:id="btnNuevoContacto" text="+ Nuevo"
                            onAction="#handleNuevoContacto" HBox.hgrow="ALWAYS"
                            style="-fx-background-color:#6c63ff; -fx-text-fill:white;
                                   -fx-background-radius:4; -fx-cursor:hand; -fx-padding:7;"/>
                    <Button fx:id="btnImportar" text="&#11014; Excel"
                            onAction="#handleImportar"
                            style="-fx-background-color:#2d4a2d; -fx-text-fill:#90e090;
                                   -fx-background-radius:4; -fx-cursor:hand; -fx-padding:7;"/>
                    <Button fx:id="btnDescargarPlantilla" text="&#11015; Plantilla"
                            onAction="#handleDescargarPlantilla"
                            style="-fx-background-color:#2d3d4a; -fx-text-fill:#90c0e0;
                                   -fx-background-radius:4; -fx-cursor:hand; -fx-padding:7;"/>
                </HBox>
            </VBox>

            <!-- PANEL DERECHO: Expediente / Timeline ───────────────────── -->
            <ScrollPane fitToWidth="true"
                        style="-fx-background:#1e1e2e; -fx-background-color:#1e1e2e;">
                <VBox fx:id="expedientePanel" spacing="12"
                      style="-fx-padding:20; -fx-background-color:#1e1e2e;">

                    <!-- Cabecera del contacto -->
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <ImageView fx:id="fotoPerfilView"
                                   fitWidth="80" fitHeight="80" preserveRatio="true"
                                   style="-fx-effect:dropshadow(gaussian,#6c63ff,10,0.4,0,0);"/>
                        <VBox spacing="4">
                            <Label fx:id="contactoNombreLabel"
                                   style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#e0e0f0;"/>
                            <Label fx:id="contactoDniLabel"
                                   style="-fx-text-fill:#9090b0; -fx-font-size:12px;"/>
                            <Label fx:id="contactoDireccionLabel"
                                   style="-fx-text-fill:#9090b0; -fx-font-size:12px;"/>
                        </VBox>
                    </HBox>

                    <!-- Chips de etiquetas -->
                    <FlowPane fx:id="etiquetasChips" hgap="6" vgap="6"/>

                    <!-- Campos dinámicos -->
                    <VBox fx:id="camposDinamicosBox" spacing="4"/>

                    <!-- Barra de acciones -->
                    <HBox spacing="8">
                        <Button fx:id="btnEditarContacto" text="&#9999;&#65039; Editar"
                                onAction="#handleEditarContacto"
                                style="-fx-background-color:#2d2d4e; -fx-text-fill:#c0c0e0;
                                       -fx-background-radius:4; -fx-cursor:hand; -fx-padding:7 12;"/>
                        <Button fx:id="btnEliminarContacto" text="&#128465;&#65039; Eliminar"
                                onAction="#handleEliminarContacto"
                                style="-fx-background-color:#3e1e1e; -fx-text-fill:#ff8080;
                                       -fx-background-radius:4; -fx-cursor:hand; -fx-padding:7 12;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnExportarPdf" text="&#128196; Exportar PDF"
                                onAction="#handleExportarPdf"
                                style="-fx-background-color:#3d2d0e; -fx-text-fill:#ffc060;
                                       -fx-background-radius:4; -fx-cursor:hand; -fx-padding:7 12;"/>
                    </HBox>

                    <Separator style="-fx-background-color:#2d2d4e;"/>

                    <!-- Encabezado timeline -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="&#128203; Expediente / Timeline"
                               style="-fx-font-size:14px; -fx-font-weight:bold; -fx-text-fill:#a78bfa;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnAgregarNota" text="&#128221; Nota"
                                onAction="#handleAgregarNota"
                                style="-fx-background-color:#2d3d4a; -fx-text-fill:#90c0e0;
                                       -fx-background-radius:4; -fx-cursor:hand; -fx-padding:6 10;"/>
                        <Button fx:id="btnAgregarMedia" text="&#128444;&#65039; Foto"
                                onAction="#handleAgregarMedia"
                                style="-fx-background-color:#2d4a2d; -fx-text-fill:#90e090;
                                       -fx-background-radius:4; -fx-cursor:hand; -fx-padding:6 10;"/>
                    </HBox>

                    <!-- Cards del timeline (generadas dinámicamente por el controller) -->
                    <VBox fx:id="timelineContainer" spacing="10"/>
                </VBox>
            </ScrollPane>
        </SplitPane>
    </center>
</BorderPane>
