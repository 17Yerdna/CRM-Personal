<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.crm.personal.presentation.controller.MainController"
            style="-fx-background-color:#fafaf5;"
            prefWidth="1200" prefHeight="760">

    <!-- ── TOOLBAR SUPERIOR ─────────────────────────────────────────────── -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="14"
              style="-fx-background-color:#fafaf5; -fx-padding:10 20;
                     -fx-border-color:#e8e4df; -fx-border-width:0 0 1 0;">
            <Label text="CRM Personal"
                   style="-fx-font-size:18px; -fx-font-weight:600; -fx-text-fill:#5c7a5f;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblContadorContactos"
                   style="-fx-text-fill:#6b6b6b; -fx-font-size:12px;"/>
        </HBox>
    </top>

    <!-- ── CONTENIDO PRINCIPAL (3 paneles) ──────────────────────────────── -->
    <center>
        <SplitPane dividerPositions="0.19, 0.43"
                   style="-fx-background-color:#fafaf5;">

            <!-- PANEL IZQUIERDO: Etiquetas + operador búsqueda ──────────── -->
            <VBox spacing="8" minWidth="170" maxWidth="260"
                  style="-fx-background-color:#ffffff; -fx-padding:16;
                         -fx-border-color:#e8e4df; -fx-border-width:0 1 0 0;">

                <Label text="Etiquetas"
                       style="-fx-font-weight:600; -fx-text-fill:#5c7a5f; -fx-font-size:14px;"/>

                <TreeView fx:id="etiquetasTreeView" VBox.vgrow="ALWAYS"
                          style="-fx-background-color:#ffffff; -fx-border-color:transparent;"/>

                <Separator style="-fx-background-color:#e8e4df;"/>

                <Label text="Operador de búsqueda:"
                       style="-fx-text-fill:#6b6b6b; -fx-font-size:11px;"/>

                <HBox spacing="14">
                    <RadioButton fx:id="radioAnd" text="AND" selected="true"
                                 style="-fx-text-fill:#2c2c2c;"
                                 onAction="#handleBuscar">
                        <toggleGroup><ToggleGroup fx:id="opGroup"/></toggleGroup>
                    </RadioButton>
                    <RadioButton fx:id="radioOr" text="OR"
                                 style="-fx-text-fill:#2c2c2c;"
                                 toggleGroup="$opGroup"
                                 onAction="#handleBuscar"/>
                </HBox>

                <Button fx:id="btnNuevaEtiqueta" text="+ Nueva Etiqueta"
                        onAction="#handleNuevaEtiqueta" maxWidth="Infinity"
                        styleClass="btn-primary"
                        style="-fx-background-radius:8; -fx-padding:10 16;"/>
                <Button fx:id="btnGestionarCampos" text="Gestionar Campos"
                        onAction="#handleGestionarCampos" maxWidth="Infinity"
                        style="-fx-background-color:#f4f4ef; -fx-text-fill:#2c2c2c;
                               -fx-background-radius:8; -fx-padding:10 16; -fx-cursor:hand;"/>
            </VBox>

            <!-- PANEL CENTRAL: Lista de contactos ──────────────────────── -->
            <VBox spacing="8" minWidth="240" maxWidth="380"
                  style="-fx-background-color:#ffffff; -fx-padding:16;
                         -fx-border-color:#e8e4df; -fx-border-width:0 1 0 0;">

                <TextField fx:id="searchField"
                           promptText="Buscar contacto..."
                           style="-fx-background-color:#f5f5f5; -fx-text-fill:#2c2c2c;
                                  -fx-border-color:transparent; -fx-border-radius:8;
                                  -fx-background-radius:8; -fx-padding:12;"/>

                <ListView fx:id="contactosListView" VBox.vgrow="ALWAYS"
                          style="-fx-background-color:#ffffff; -fx-border-color:transparent;"/>

                <HBox spacing="8">
                    <Button fx:id="btnNuevoContacto" text="+ Nuevo"
                            onAction="#handleNuevoContacto" HBox.hgrow="ALWAYS"
                            styleClass="btn-primary"
                            style="-fx-background-radius:8; -fx-padding:10 16;"/>
                    <Button fx:id="btnImportar" text="Importar"
                            onAction="#handleImportar"
                            style="-fx-background-color:transparent; -fx-text-fill:#7a9e7e;
                                   -fx-border-color:#7a9e7e; -fx-border-radius:8;
                                   -fx-background-radius:8; -fx-padding:10 16; -fx-cursor:hand;"/>
                    <Button fx:id="btnDescargarPlantilla" text="Plantilla"
                            onAction="#handleDescargarPlantilla"
                            style="-fx-background-color:transparent; -fx-text-fill:#7a9e7e;
                                   -fx-border-color:#7a9e7e; -fx-border-radius:8;
                                   -fx-background-radius:8; -fx-padding:10 16; -fx-cursor:hand;"/>
                </HBox>
            </VBox>

            <!-- PANEL DERECHO: Expediente / Timeline ───────────────────── -->
            <ScrollPane fitToWidth="true"
                        style="-fx-background:#fafaf5; -fx-background-color:#fafaf5;">
                <VBox fx:id="expedientePanel" spacing="12"
                      style="-fx-padding:20; -fx-background-color:#ffffff;">

                    <!-- Cabecera del contacto -->
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <ImageView fx:id="fotoPerfilView"
                                   fitWidth="80" fitHeight="80" preserveRatio="true"
                                   style="-fx-effect:dropshadow(gaussian,rgba(122,158,126,0.2),8,0.3,0,0);
                                          -fx-background-radius:999;"/>
                        <VBox spacing="4">
                            <Label fx:id="contactoNombreLabel"
                                   style="-fx-font-size:20px; -fx-font-weight:bold; -fx-text-fill:#2c2c2c;"/>
                            <Label fx:id="contactoDniLabel"
                                   style="-fx-text-fill:#6b6b6b; -fx-font-size:12px;"/>
                            <Label fx:id="contactoDireccionLabel"
                                   style="-fx-text-fill:#6b6b6b; -fx-font-size:12px;"/>
                        </VBox>
                    </HBox>

                    <!-- Chips de etiquetas -->
                    <FlowPane fx:id="etiquetasChips" hgap="6" vgap="6"/>

                    <!-- Campos dinámicos -->
                    <VBox fx:id="camposDinamicosBox" spacing="8"/>

                    <!-- Barra de acciones -->
                    <HBox spacing="8">
                        <Button fx:id="btnEditarContacto" text="Editar"
                                onAction="#handleEditarContacto"
                                style="-fx-background-color:transparent; -fx-text-fill:#7a9e7e;
                                       -fx-border-color:#7a9e7e; -fx-border-radius:8;
                                       -fx-background-radius:8; -fx-cursor:hand; -fx-padding:8 14;"/>
                        <Button fx:id="btnEliminarContacto" text="Eliminar"
                                onAction="#handleEliminarContacto"
                                style="-fx-background-color:transparent; -fx-text-fill:#ba1a1a;
                                       -fx-border-color:#ffdad6; -fx-border-radius:8;
                                       -fx-background-radius:8; -fx-cursor:hand; -fx-padding:8 14;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnExportarPdf" text="Exportar PDF"
                                onAction="#handleExportarPdf"
                                style="-fx-background-color:transparent; -fx-text-fill:#7a9e7e;
                                       -fx-border-color:#7a9e7e; -fx-border-radius:8;
                                       -fx-background-radius:8; -fx-cursor:hand; -fx-padding:8 14;"/>
                    </HBox>

                    <Separator style="-fx-background-color:#e8e4df;"/>

                    <!-- Encabezado timeline -->
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Expediente"
                               style="-fx-font-size:16px; -fx-font-weight:600; -fx-text-fill:#5c7a5f;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="btnAgregarNota" text="+ Nota"
                                onAction="#handleAgregarNota"
                                styleClass="btn-primary"
                                style="-fx-background-radius:8; -fx-padding:6 12; -fx-font-size:12px;"/>
                        <Button fx:id="btnAgregarMedia" text="+ Foto"
                                onAction="#handleAgregarMedia"
                                style="-fx-background-color:transparent; -fx-text-fill:#7a9e7e;
                                       -fx-border-color:#7a9e7e; -fx-border-radius:8;
                                       -fx-background-radius:8; -fx-cursor:hand; -fx-padding:6 12; -fx-font-size:12px;"/>
                    </HBox>

                    <!-- Timeline container -->
                    <VBox fx:id="timelineContainer" spacing="8"/>

                </VBox>
            </ScrollPane>

        </SplitPane>
    </center>

</BorderPane>
