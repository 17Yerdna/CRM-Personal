<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/21"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.crm.personal.presentation.controller.CampoManagerController"
      spacing="16"
      style="-fx-background-color:#fafaf5; -fx-padding:20;"
      prefWidth="600" prefHeight="480">

    <!-- Panel izquierdo: lista -->
    <VBox spacing="8" prefWidth="280"
          style="-fx-background-color:#ffffff; -fx-background-radius:12;
                 -fx-border-color:#e8e4df; -fx-border-radius:12; -fx-border-width:1;
                 -fx-padding:16;">
        <Label text="Campos personalizados"
               style="-fx-font-weight:600; -fx-text-fill:#5c7a5f; -fx-font-size:14px;"/>
        <ListView fx:id="camposList" VBox.vgrow="ALWAYS"
                  style="-fx-background-color:#ffffff; -fx-border-color:transparent;"/>
        <HBox spacing="6">
            <Button fx:id="btnNuevo" text="+ Nuevo"
                    onAction="#handleNuevo" HBox.hgrow="ALWAYS"
                    styleClass="btn-primary"
                    style="-fx-background-radius:8; -fx-padding:8 16;"/>
            <Button fx:id="btnEliminar" text="Eliminar"
                    onAction="#handleEliminar"
                    style="-fx-background-color:#ffdad6; -fx-text-fill:#ba1a1a;
                           -fx-background-radius:8; -fx-cursor:hand; -fx-padding:8 12;"/>
        </HBox>
    </VBox>

    <!-- Panel derecho: formulario -->
    <VBox spacing="14" HBox.hgrow="ALWAYS"
          style="-fx-background-color:#ffffff; -fx-background-radius:12;
                 -fx-border-color:#e8e4df; -fx-border-radius:12; -fx-border-width:1;
                 -fx-padding:24;">
        <Label text="Editar campo"
               style="-fx-font-weight:600; -fx-text-fill:#5c7a5f; -fx-font-size:14px;"/>
        <Separator/>

        <Label text="Nombre:" style="-fx-text-fill:#6b6b6b; -fx-font-size:11px;"/>
        <TextField fx:id="nombreField" promptText="Nombre del campo"
                   style="-fx-background-color:#ffffff; -fx-text-fill:#2c2c2c;
                          -fx-border-color:#e8e4df; -fx-border-radius:8;
                          -fx-background-radius:8; -fx-padding:10 12;"/>

        <Label text="Tipo:" style="-fx-text-fill:#6b6b6b; -fx-font-size:11px;"/>
        <ComboBox fx:id="tipoCombo" maxWidth="Infinity"
                  style="-fx-background-color:#ffffff; -fx-background-radius:8;
                         -fx-border-color:#e8e4df; -fx-border-radius:8;"/>

        <CheckBox fx:id="activoCheck" text="Activo"
                  style="-fx-text-fill:#2c2c2c;"/>

        <Region VBox.vgrow="ALWAYS"/>

        <HBox spacing="8" alignment="CENTER_RIGHT">
            <Button text="Cerrar"
                    onAction="#handleCerrar"
                    style="-fx-background-color:#f4f4ef; -fx-text-fill:#2c2c2c;
                           -fx-background-radius:8; -fx-cursor:hand; -fx-padding:8 16;"/>
            <Button fx:id="btnGuardar" text="Guardar"
                    onAction="#handleGuardar"
                    styleClass="btn-primary"
                    style="-fx-font-weight:600; -fx-background-radius:8;
                           -fx-cursor:hand; -fx-padding:8 20;"/>
        </HBox>
    </VBox>
</HBox>
